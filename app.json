{
  "expo": {
    "name": "PlusOne",
    "slug": "plusone",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "plusone",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#340074"
    },
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.plusone.app.makesureNoOneIsLeftOut",
      "buildNumber": "7",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to show nearby events and help you find places to meet new people.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.plusone.app.makesureNoOneIsLeftOut",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-app-icon-foreground.png",
        "backgroundImage": "./assets/images/android-app-icon-background.png",
        "monochromeImage": "./assets/images/android-app-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {}
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-splash-screen",
      "expo-router",
      "expo-font",
      "expo-video",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.934516385017-tqt7ahbq2r6muockmdlp7hndjdu1ia3r"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icon.png",
          "color": "#340074"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      "./plugins/withPhoneOnlyScreens",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5a1ed0c2-d9a1-4610-a8f5-5a6675777fc3"
      }
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/5a1ed0c2-d9a1-4610-a8f5-5a6675777fc3"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
