# Frontend (Expo) env
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# iOS/Android deep link scheme (optional if using custom scheme)
EXPO_PUBLIC_DEEP_LINK_SCHEME=plusone

# WebSocket base will follow API base by replacing http->ws automatically in ws helper
